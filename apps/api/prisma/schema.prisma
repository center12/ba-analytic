generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String                  @id @default(cuid())
  name            String
  description     String?
  overview        String?                 @db.Text
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  features        Feature[]
  pipelineConfigs ProjectPipelineConfig[]
}

model AppFeedback {
  id           String   @id @default(cuid())
  content      String   @db.Text
  routePath    String
  pageTitle    String?
  contextLabel String?
  originalName String?
  storageKey   String?
  mimeType     String?
  createdAt    DateTime @default(now())
}

model ProjectPipelineConfig {
  id        String   @id @default(cuid())
  projectId String
  step      Int      // 1 | 2 | 3 | 4 | 5
  provider  String   // 'gemini' | 'claude' | 'openai'
  model     String?  // null = provider default
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step])
}

model Feature {
  id                    String         @id @default(cuid())
  projectId             String
  code                  String
  name                  String
  description           String?
  content               String?        @db.Text
  featureType           FeatureType    @default(FEATURE)
  relatedFeatureIds     Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  extractedRequirements Json?
  extractedBehaviors    Json?
  layer1SSR             String?        @db.Text  // JSON: SSRData
  layer1Stories         String?        @db.Text  // JSON: UserStories
  layer1Mapping         String?        @db.Text  // JSON: Mapping
  layer1Validation      String?        @db.Text  // JSON: ValidationResult
  testScenarios         Json?
  devPlanWorkflow       String?        @db.Text  // JSON: WorkflowStep[]
  devPlanBackend        String?        @db.Text  // JSON: BackendPlan
  devPlanFrontend       String?        @db.Text  // JSON: FrontendPlan
  devPlanTesting        String?        @db.Text  // JSON: TestingPlan
  devPromptApi          String?
  devPromptFrontend     String?
  devPromptTesting      String?
  pipelineStatus        PipelineStatus @default(IDLE)
  pipelineStep          Int?
  pipelineFailedAt      Int?
  pipelinePartial       Json?

  // Document versioning
  contentStatus         ContentStatus @default(DRAFT)
  publishedVersion      Int           @default(0)
  publishedContent      String?       @db.Text     // snapshot of last published content (for diff)

  // SSR extraction & sync tracking
  extractedFromSSRId    String?                    // FK to parent SSR feature (nullable)
  extractedRequirementIds Json?                    // Array of requirement IDs: ["US-001", "US-002"]
  syncStatus            FeatureSyncStatus @default(IN_SYNC)  // Tracks if extracted feature is in sync with parent SSR
  lastSyncedWithSSRAt   DateTime?                  // Timestamp of last successful sync
  syncChangeReason      String?                    // 'document_published' | 'story_changed'

  project               Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  extractedFromSSR      Feature?      @relation("ExtractedFrom", fields: [extractedFromSSRId], references: [id], onDelete: SetNull)
  extractedFeatures     Feature[]     @relation("ExtractedFrom")
  baDocument            BADocument?
  screenshots           Screenshot[]
  featureAnalyses       FeatureAnalysis[]
  chatSessions          ChatSession[]
  developerTasks        DeveloperTask[]
  featureChangelogs     FeatureChangelog[]

  @@unique([projectId, code])
  @@index([extractedFromSSRId])
  @@index([extractedFromSSRId, syncStatus])
}

model FeatureChangelog {
  id              String   @id @default(cuid())
  featureId       String
  version         Int
  contentSnapshot String   @db.Text
  changeSummary   String?  @db.Text  // AI-generated diff, null until AI finishes
  layerSnapshot   Json?              // { layer1Stories, layer1SSR, layer1Mapping, layer1Validation } for change detection on next publish
  publishedAt     DateTime @default(now())
  feature         Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
}

model BADocument {
  id           String   @id @default(cuid())
  featureId    String   @unique
  originalName String
  storageKey   String
  mimeType     String
  uploadedAt   DateTime @default(now())
  feature      Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id           String   @id @default(cuid())
  featureId    String
  originalName String
  storageKey   String
  mimeType     String
  uploadedAt   DateTime @default(now())
  feature      Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model FeatureAnalysis {
  id           String           @id @default(cuid())
  featureId    String
  title        String
  description  String?
  preconditions String?
  priority     FeatureAnalysisPriority @default(MEDIUM)
  status       FeatureAnalysisStatus   @default(DRAFT)
  steps           Json
  requirementRefs Json?           // Array of US-xx / FR-xx / BR-xx IDs from the scenario
  aiProvider      String
  modelVersion    String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  feature         Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  featureId String
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  feature   Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String
  createdAt DateTime        @default(now())
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum FeatureAnalysisPriority {
  HIGH
  MEDIUM
  LOW
}

enum FeatureAnalysisStatus {
  DRAFT
  APPROVED
  DEPRECATED
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum PipelineStatus {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

enum FeatureType {
  SSR
  FEATURE
}

enum DevTaskCategory {
  API
  FRONTEND
  TESTING
}

enum FeatureSyncStatus {
  IN_SYNC
  OUT_OF_SYNC
  DIVERGED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DeveloperTask {
  id        String          @id @default(cuid())
  featureId String
  category      DevTaskCategory
  title         String
  prompt        String          @db.Text
  userStoryIds  Json?           // Array of US-xx IDs this task implements
  createdAt     DateTime        @default(now())
  feature       Feature         @relation(fields: [featureId], references: [id], onDelete: Cascade)
}
