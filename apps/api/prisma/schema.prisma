generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String                  @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  features        Feature[]
  pipelineConfigs ProjectPipelineConfig[]
}

model ProjectPipelineConfig {
  id        String   @id @default(cuid())
  projectId String
  step      Int      // 1 | 2 | 3 | 4 | 5
  provider  String   // 'gemini' | 'claude' | 'openai'
  model     String?  // null = provider default
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step])
}

model Feature {
  id                    String         @id @default(cuid())
  projectId             String
  name                  String
  description           String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  extractedRequirements Json?
  extractedBehaviors    Json?
  testScenarios         Json?
  devPlanWorkflow       String?        @db.Text  // JSON: WorkflowStep[]
  devPlanBackend        String?        @db.Text  // JSON: BackendPlan
  devPlanFrontend       String?        @db.Text  // JSON: FrontendPlan
  devPlanTesting        String?        @db.Text  // JSON: TestingPlan
  devPromptApi          String?
  devPromptFrontend     String?
  devPromptTesting      String?
  pipelineStatus        PipelineStatus @default(IDLE)
  pipelineStep          Int?
  pipelineFailedAt      Int?
  pipelinePartial       Json?
  project               Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  baDocument            BADocument?
  screenshots           Screenshot[]
  testCases             TestCase[]
  chatSessions          ChatSession[]
  developerTasks        DeveloperTask[]
}

model BADocument {
  id           String   @id @default(cuid())
  featureId    String   @unique
  originalName String
  storageKey   String
  mimeType     String
  uploadedAt   DateTime @default(now())
  feature      Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id           String   @id @default(cuid())
  featureId    String
  originalName String
  storageKey   String
  mimeType     String
  uploadedAt   DateTime @default(now())
  feature      Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model TestCase {
  id           String           @id @default(cuid())
  featureId    String
  title        String
  description  String?
  preconditions String?
  priority     TestCasePriority @default(MEDIUM)
  status       TestCaseStatus   @default(DRAFT)
  steps        Json
  aiProvider   String
  modelVersion String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  feature      Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  featureId String
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  feature   Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String
  createdAt DateTime        @default(now())
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum TestCasePriority {
  HIGH
  MEDIUM
  LOW
}

enum TestCaseStatus {
  DRAFT
  APPROVED
  DEPRECATED
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum PipelineStatus {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

enum DevTaskCategory {
  API
  FRONTEND
  TESTING
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DeveloperTask {
  id        String          @id @default(cuid())
  featureId String
  category  DevTaskCategory
  title     String
  prompt    String          @db.Text
  createdAt DateTime        @default(now())
  feature   Feature         @relation(fields: [featureId], references: [id], onDelete: Cascade)
}
